@InProceedings{kajiya,
    author = {Kajiya, J. T. and Kay, T. L.},
    title = {Rendering fur with three dimensional textures},
    year = {1989},
    isbn = {0897913124},
    publisher = {Association for Computing Machinery},
    address = {New York, NY, USA},
    url = {https://doi.org/10.1145/74333.74361},
    abstract = {We present a method for rendering scenes with fine detail via an object called a texel, a rendering primitive inspired by volume densities mixed with anisotropic lighting models. This technique solves a long outstanding problem in image synthesis: the rendering of furry surfaces.},
    booktitle = {Proceedings of the 16th Annual Conference on Computer Graphics and Interactive Techniques},
    pages = {271–280},
    numpages = {10},
    series = {SIGGRAPH '89},
    annote    = {In this paper, Kajiya and Kay propose a method of rendering fur via texels --- three-dimensional texture maps that hold normal, tangent, bitangent, and lighting model information. These texels are independent of geometry making their rendering cost independent of the complexity of a model's geometry. The paper lays out the algorithm for placing and rendering texels. It also describes a lighting model for the method, including handling for ray intersection. This is a seminal paper in the realm volumetric fur rendering and it is often referenced in later research. This was published by ACM SIGGRAPH, the premier computer graphics conference, indicating it is likely of high quality. Though not directly applicable to my research, this paper does include conceptual groundwork that is used in other volumetric fur rendering literature.}
}

@InProceedings{lengyel,
    author = {Lengyel, Jerome and Praun, Emil and Finkelstein, Adam and Hoppe, Hugues},
    title = {Real-time fur over arbitrary surfaces},
    year = {2001},
    isbn = {1581132921},
    publisher = {Association for Computing Machinery},
    address = {New York, NY, USA},
    url = {https://doi.org/10.1145/364338.364407},
    booktitle = {Proceedings of the 2001 Symposium on Interactive 3D Graphics},
    pages = {227–232},
    numpages = {6},
    keywords = {volume textures, lapped textures, hair rendering},
    series = {I3D '01},
    annote = {The authors of this paper describe a technique for real-time fur rendering on arbitrary topology. This method invovles several steps. First, the mesh is used for geometry pre-processing in which patches of lapped textures are placed upon the mesh. Next comes texture pre-processing. In this step strand geometry is generated via a particle system simulation, upon which textures shell and fin textures are placed. Shell textures are semi-transparent two-dimensional textures, which, when layered along the normals, creates the illusion of volume. While shells form the body of the fur, fin textures are only rendered along the model's silhouette where they can hide visual discontinuities left by the shells. At runtime, the surface of the model is rendered first, then the fins, and finally the shells. This paper is the basis of shell and fins fur rendering making it an important paper for my research. Published by ACM and authored by several computer graphics specialists, this paper is frequently cited in other shell-based fur rendering papers.}
}

@article{andersen2016hybrid,
  author  = {Andersen, Tobias Gr{\o}nbeck and Falster, Viggo and Frisvad, Jeppe Revall and Christensen, Niels J{\o}rgen},
  title   = {Hybrid fur rendering: combining volumetric fur with explicit hair strands},
  journal = {The Visual Computer},
  year    = {2016},
  volume  = {32},
  number  = {6},
  pages   = {739-749},
  url     = {https://doi.org/10.1007/s00371-016-1252-x},
  annote = {A paper about combining volumetric fur rendering techniques and geometric fur rendering techniques for realistic fur rendering. As described in the paper, many animals have both guard hairs and an undercoat. Geometric fur, rendered per-strand, is good at simulating guard hairs but is less convincing for the dense undercoat. Volumentric rendering can render dense fur efficiently but struggles to model longer, individual strands. By rendering per-strand fur atop the volumetric layer, a more realistic fur can be achieved. While this approach is not directly related to mine, it does show how volumetric fur rendering is still applicable in newer fur rendering techniques. This article was published in a peer reviewed journal, indicating a greater likelihood of quality.}
}

@inproceedings{strands2cards,
author = {Tojo, Kenji and Hu, Liwen and Umetani, Nobuyuki and Li, Hao},
title = {Strands2Cards: Automatic Generation of Hair Cards from Strands},
year = {2025},
isbn = {9798400721373},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3757377.3763864},
abstract = {We present a method for automatically converting strand-based hair models into an efficient mesh-based representation, known as hair cards, for real-time rendering. Our method takes strands as inputs and outputs polygon strips with semi-transparent texture, preserving the appearance of the original strand-based hairstyle. To achieve this, we first cluster strands into groups, referred to as wisps, and generate hairstyle-preserving texture maps for each wisp by skinning-based alignment of the strands into a normalized pose in UV space. These textures can further be shared among similar wisps to better utilize the limited texture resolution. Next, polygon strips are fitted to the clustered strands via tailored differentiable rendering that can optimize transparent cluster-colored coverage masks. The proposed method successfully handles a wide range of hair models and outperforms existing approaches in representing volumetric hairstyles such as curly and wavy ones. Furthermore, our strip optimization can efficiently convert a full-hair model with more than 100 thousand strands within 20 seconds. Our method was extensively tested on both a hair database and many complex real-world hairstyles acquired using state-of-the-art hair capture methods.},
booktitle = {Proceedings of the SIGGRAPH Asia 2025 Conference Papers},
articleno = {105},
numpages = {11},
keywords = {Real-time rendering, hair rendering, hair modeling, hair cards.},
location = {
},
series = {SA Conference Papers '25}
}

@article{marschner,
author = {Marschner, Stephen R. and Jensen, Henrik Wann and Cammarano, Mike and Worley, Steve and Hanrahan, Pat},
title = {Light scattering from human hair fibers},
year = {2003},
issue_date = {July 2003},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {22},
number = {3},
issn = {0730-0301},
url = {https://doi.org/10.1145/882262.882345},
abstract = {Light scattering from hair is normally simulated in computer graphics using Kajiya and Kay's classic phenomenological model. We have made new measurements of scattering from individual hair fibers that exhibit visually significant effects not predicted by Kajiya and Kay's model. Our measurements go beyond previous hair measurements by examining out-of-plane scattering, and together with this previous work they show a multiple specular highlight and variation in scattering with rotation about the fiber axis. We explain the sources of these effects using a model of a hair fiber as a transparent elliptical cylinder with an absorbing interior and a surface covered with tilted scales. Based on an analytical scattering function for a circular cylinder, we propose a practical shading model for hair that qualitatively matches the scattering behavior shown in the measurements. In a comparison between a photograph and rendered images, we demonstrate the new model's ability to match the appearance of real hair.},
journal = {ACM Trans. Graph.},
month = jul,
pages = {780–791},
numpages = {12},
keywords = {fibers, hair, optical scattering, rendering}
}

